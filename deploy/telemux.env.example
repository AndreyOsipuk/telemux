# Конфигурация telemux (/etc/telemux/telemux.env). Читается systemd-юнитом.

# DSN локального PostgreSQL. Держать на loopback, наружу не открывать.
DATABASE_URL=postgres://telemux:CHANGE_ME@127.0.0.1:5432/telemux?sslmode=disable

# telemt machine-API ноды (локально).
TELEMT_API_URL=http://127.0.0.1:9091
# Значение заголовка Authorization (если в [server.api] задан auth_header).
TELEMT_API_AUTH=

# Адрес HTTP-демона (веб-морда + API). Держать за фаерволом/реверс-прокси.
TELEMUX_LISTEN=127.0.0.1:8080

# Авторизация панели. Если пароль пуст — auth ВЫКЛЮЧЕН (открытый режим за фаерволом).
TELEMUX_ADMIN_USER=admin
TELEMUX_ADMIN_PASSWORD=
